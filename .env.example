# Server Configuration
PORT=3000
NODE_ENV=production

# SSL Configuration (for scraping HTTPS sites)
NODE_TLS_REJECT_UNAUTHORIZED=0

# Optional: gunakan backend scraper non-Vercel (Railway/Render/VPS)
# Contoh: https://otakudesu-scraper.up.railway.app
SCRAPER_BACKEND_URL=

# Optional: paksa pakai data snapshot (tanpa scraping live)
FORCE_SNAPSHOT_MODE=false
